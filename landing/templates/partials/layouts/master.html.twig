<!DOCTYPE html>
<html lang="en">

<head>
    <title>Generation Next 2026 - Harare Leadership Conference</title>
    <link rel="icon" href="assets/images/gennext/logos/favicon.png" type="image/png" sizes="32x32">
    <meta content="text/html;charset=utf-8" http-equiv="Content-Type">
    <meta content="width=device-width, initial-scale=1.0" name="viewport" >
    <meta content="Generation Next 2026 gathers church leaders, founders, and faith enthusiasts at Celebration Centre, Borrowdale, Harare from July 16-18, 2026." name="description" >
    <meta content="Generation Next, Harare, church leadership, prophetic anointing, Harvest House International" name="keywords" >
    <meta content="Generation Next" name="author" >

    {% include 'partials/head-css.html.twig' %}

</head>

    {% include 'partials/body.html.twig' %}
    {% include 'partials/preloader.html.twig' %}
    {% include 'partials/header.html.twig' %}

     {% block page_contents %}
<!-- Default content, replace or extend as needed -->
        <p>Success</p>
    {% endblock %}

<!-- footer -->
    {% include 'partials/footer.html.twig' %}

<!-- javascripts -->

    {% block javascripts %}
    {% include 'partials/vendor-scripts.html.twig' %}
    {% block vendor_scripts %}{% endblock %}
    {% block page_scripts %}{% endblock %}
    {% endblock %}

<script>
(function () {
  var sections = ['about','why-attend','speakers','schedule','venue','faq'];
  function scrollToSection(id) {
    var el = document.getElementById(id);
    if (el) { el.scrollIntoView({ behavior: 'smooth' }); }
  }
  // On load: if path matches a section, scroll to it
  var path = window.location.pathname.replace(/^\//, '').replace(/\/$/, '');
  if (sections.indexOf(path) !== -1) { scrollToSection(path); }
  // Intercept nav clicks: update URL cleanly and scroll
  document.addEventListener('click', function (e) {
    var a = e.target.closest('a[href]');
    if (!a) return;
    var href = a.getAttribute('href');
    var slug = href.replace(/^\//, '');
    if (sections.indexOf(slug) !== -1) {
      e.preventDefault();
      history.pushState(null, '', '/' + slug);
      scrollToSection(slug);
    }
  });
})();
</script>

</body>
</html>
